# Backend key used only on serverless function /api/chat
GROQ_API_KEY=
# Optional override (defaults to llama3-8b-8192)
GROQ_MODEL=llama3-8b-8192

# Frontend variables
REACT_APP_FORMSPREE_ENDPOINT=https://formspree.io/f/your-form-id
REACT_APP_CHAT_API_URL=
REACT_APP_API_URL=
# Google OAuth (GET YOUR ACTUAL CLIENT ID FROM GOOGLE CLOUD)
REACT_APP_GOOGLE_CLIENT_ID=
